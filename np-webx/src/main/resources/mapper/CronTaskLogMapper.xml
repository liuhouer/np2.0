<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.northpark.mapper.CronTaskLogMapper">

    <resultMap id="BaseResultMap" type="cn.northpark.model.CronTaskLog">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="task_id" property="taskId" jdbcType="BIGINT"/>
        <result column="task_name" property="taskName" jdbcType="VARCHAR"/>
        <result column="execute_type" property="executeType" jdbcType="VARCHAR"/>
        <result column="execute_params" property="executeParams" jdbcType="VARCHAR"/>
        <result column="start_time" property="startTime" jdbcType="TIMESTAMP"/>
        <result column="end_time" property="endTime" jdbcType="TIMESTAMP"/>
        <result column="duration" property="duration" jdbcType="BIGINT"/>
        <result column="status" property="status" jdbcType="VARCHAR"/>
        <result column="error_msg" property="errorMsg" jdbcType="VARCHAR"/>
        <result column="log_content" property="logContent" jdbcType="VARCHAR"/>
        <result column="create_by" property="createBy" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, task_id, task_name, execute_type, execute_params, start_time, end_time, 
        duration, status, error_msg, log_content, create_by
    </sql>

    <select id="findByTaskId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM bc_cron_task_log
        WHERE task_id = #{taskId}
        ORDER BY start_time DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countByTaskId" resultType="int">
        SELECT COUNT(*)
        FROM bc_cron_task_log
        WHERE task_id = #{taskId}
    </select>

    <select id="findById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM bc_cron_task_log
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="cn.northpark.model.CronTaskLog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO bc_cron_task_log (task_id, task_name, execute_type, execute_params, start_time, status, create_by)
        VALUES (#{taskId}, #{taskName}, #{executeType}, #{executeParams}, #{startTime}, #{status}, #{createBy})
    </insert>

    <update id="update" parameterType="cn.northpark.model.CronTaskLog">
        UPDATE bc_cron_task_log
        <set>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="duration != null">duration = #{duration},</if>
            <if test="status != null">status = #{status},</if>
            <if test="errorMsg != null">error_msg = #{errorMsg},</if>
            <if test="logContent != null">log_content = #{logContent},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM bc_cron_task_log WHERE id = #{id}
    </delete>

</mapper>